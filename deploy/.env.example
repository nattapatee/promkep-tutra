# =============================================================================
# /opt/promkep-tutra/.env — copy to .env on the droplet and fill in.
# Loaded by `docker compose` (variable substitution + api service env_file).
# =============================================================================

# ─── Image registry ──────────────────────────────────────────────────────────
GH_OWNER=nattapatee
GH_REPO=promkep-tutra
IMAGE_TAG=latest

# ─── Caddy domains (A-record → droplet IP, snippet appended to pwt-tx Caddy) ─
