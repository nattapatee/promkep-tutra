# =============================================================================
# /opt/promkep-tutra/.env — copy to .env on the droplet and fill in.
# Loaded by `docker compose` (variable substitution + api service env_file).
# =============================================================================

# ─── Image registry ──────────────────────────────────────────────────────────
GH_OWNER=araiwaha
GH_REPO=promkep-tutra
IMAGE_TAG=latest

# ─── Caddy domains (A-record → droplet IP, snippet appended to pwt-tx Caddy) ─
DOMAIN_API=promkep-api.alizoft.site
DOMAIN_WEB=promkep-web.alizoft.site

# ─── api/.env values ─────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production
DATABASE_URL=file:/app/data/dev.db

# ─── LINE Messaging API (own channel — separate from pwt-tx) ─────────────────
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=

# LINE Login (LIFF) — can reuse Araiwa channel from pwt-tx.
LINE_LOGIN_CHANNEL_ID=2009912247

ADMIN_LINE_USER_IDS=
CORS_ALLOWED_ORIGINS=https://promkep-web.alizoft.site
WEB_BASE_URL=https://promkep-web.alizoft.site
DISABLE_DEV_AUTH_HEADER=1

# ─── AI ──────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
