# Server
PORT=3001
NODE_ENV=development

# Database (SQLite — separate file from pwt-tx)
DATABASE_URL="file:./dev.db"

# LINE Messaging API (https://developers.line.biz/console/)
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=

# LINE Login (LIFF) — for verifying ID tokens from web/
LINE_LOGIN_CHANNEL_ID=

# CORS allowed origins (comma-separated)
CORS_ALLOWED_ORIGINS=http://localhost:3010

# Public web base URL (used for rich-menu URIs and Flex CTA buttons)
WEB_BASE_URL=

# Public API base URL — used to host PromptPay QR PNGs reachable via HTTPS for LINE Flex
API_BASE_URL=http://localhost:3001

# Comma-separated LINE userIds who get role=admin on first contact
ADMIN_LINE_USER_IDS=

# Google Gemini API key (https://aistudio.google.com/apikey) — used by AI secretary
GEMINI_API_KEY=
